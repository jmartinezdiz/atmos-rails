%h2= I18n.t("views.countries.text.show_text", location: country_political_division_breadcrumb(country_political_division)).html_safe

- if country_political_division.lower_country_political_divisions.any?
  .custom-list-wrapper
    %h2= I18n.t("views.countries.text.select_political_division", name: country_political_division.lower_country_political_divisions.first.country_political_division_type.name)
    %ul.custom-list
      - country_political_division.lower_country_political_divisions.order(:"name_#{I18n.locale}").each do |lower_division|
        %li
          = link_to lower_division.name, political_division_country_path(lower_division.country, political_division_id: lower_division)

= render "country_political_divisions/show_forecast", country_political_division: country_political_division, start_date: start_date
